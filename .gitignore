node_modules/
.npm/
.pnpm-store/
.yarn/
docs/.vitepress/cache/
docs/.vitepress/dist/
.vite/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local tools, logs and temporary files
.tools/
.cache/
/work/
/sts2-api-signatures/
*.log
*.tmp
*.bak
*.orig
*.dmp
godot.log
/core
